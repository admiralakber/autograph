{
  "name": "autograph-coordinator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Autograph v2 swarm coordinator — a PartyServer-on-Cloudflare-Durable-Objects room that holds one shared MAP-Elites archive (the archipelago) and the signed lineage. Sandboxed, undeployed by design.",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsc --noEmit && tsc -p client/tsconfig.json --noEmit && tsc -p test/tsconfig.json --noEmit",
    "smoke": "node --experimental-strip-types --no-warnings scripts/smoke.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "make-fixture": "node --experimental-strip-types --no-warnings scripts/make-fixture.ts",
    "dev": "wrangler dev",
    "ws-smoke": "node --experimental-strip-types --no-warnings scripts/ws-smoke.ts",
    "check": "npm run typecheck && npm run smoke"
  },
  "dependencies": {
    "partyserver": "^0.5.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.10",
    "@cloudflare/workers-types": "^4.20260426.1",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.95.0"
  }
}
